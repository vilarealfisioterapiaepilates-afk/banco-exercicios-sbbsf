<script>
function atualizarSlider(campo, valor) {
  document.getElementById('val-' + campo).textContent = valor;
  const slider = document.getElementById('sl-' + campo);
  const pct = (valor - 1) / 6 * 100;
  const cor = valor <= 2 ? '#009933' : valor <= 4 ? '#E8A020' : '#C0392B';
  slider.style.background = `linear-gradient(to right, ${cor} ${pct}%, #E5E7EB ${pct}%)`;
  document.getElementById('val-' + campo).style.color = cor;
}
function calcularHooper() {
  const sono = parseInt(document.getElementById('sl-sono').value);
  const estresse = parseInt(document.getElementById('sl-estresse').value);
  const fadiga = parseInt(document.getElementById('sl-fadiga').value);
  const dor = parseInt(document.getElementById('sl-dor').value);
  const total = sono + estresse + fadiga + dor;
  const el = document.getElementById('resultado-hooper');
  const emoji = document.getElementById('res-emoji');
  const titulo = document.getElementById('res-titulo');
  const score = document.getElementById('res-score');
  const protocolo = document.getElementById('res-protocolo');
  const alerta = document.getElementById('res-alerta');
  el.style.display = 'block';
  el.className = 'resultado-hooper';
  if (total <= 16) {
    el.classList.add('verde');
    emoji.textContent = '🟢';
    titulo.textContent = 'Zona Verde — Você está bem recuperada';
    score.textContent = `Hooper total: ${total} pontos (sono: ${sono} | estresse: ${estresse} | fadiga: ${fadiga} | dor: ${dor})`;
    protocolo.innerHTML = `<strong>Protocolo de hoje:</strong><br>✅ FIFA 11+ completo — Partes 1 + 3 (18 min antes do jogo)<br>✅ Ativação glútea normal<br>✅ Mobilização específica conforme queixa<br>✅ Pós-jogo: protocolo completo + CWI se disponível`;
    alerta.textContent = 'Avise a Gabi que está verde. Continue o monitoramento pós-jogo normalmente.';
  } else if (total <= 20) {
    el.classList.add('amarelo');
    emoji.textContent = '🟡';
    titulo.textContent = 'Zona Amarela — Atenção redobrada hoje';
    score.textContent = `Hooper total: ${total} pontos (sono: ${sono} | estresse: ${estresse} | fadiga: ${fadiga} | dor: ${dor})`;
    protocolo.innerHTML = `<strong>Protocolo de hoje:</strong><br>⚠️ FIFA 11+: Parte 1 apenas (corrida + mobilidade — 8 min)<br>⚠️ Ativação glútea leve (1 série apenas)<br>⚠️ Sem excêntrico pesado ou pliometria intensa<br>✅ Mobilização de tornozelo e quadril<br>✅ Pós-jogo: priorizar CWI + foam rolling + sono 9h`;
    alerta.textContent = 'Avise a Gabi que está amarela. Ela vai confirmar ou ajustar o protocolo antes do jogo.';
  } else {
    el.classList.add('vermelho');
    emoji.textContent = '🔴';
    titulo.textContent = 'Zona Vermelha — Corpo em alerta. Protocolo conservador.';
    score.textContent = `Hooper total: ${total} pontos (sono: ${sono} | estresse: ${estresse} | fadiga: ${fadiga} | dor: ${dor})`;
    protocolo.innerHTML = `<strong>Protocolo de hoje:</strong><br>🔴 Pré-jogo: apenas mobilização articular suave (10 min)<br>🔴 Sem FIFA 11+ intenso, sem pliometria, sem excêntrico<br>🔴 Ativação glútea mínima: 1 série de clamshell leve<br>🔴 Pós-jogo: CWI obrigatório + foam rolling + sono 9–10h`;
    alerta.textContent = '⚠️ Avise a Gabi IMEDIATAMENTE. Ela precisa saber antes do aquecimento para comunicar a comissão técnica se necessário.';
  }
  el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}
function copiarMensagem(btn) {
  const msg = btn.parentElement;
  const texto = msg.innerText.replace('📋 Copiar mensagem', '').trim();
  navigator.clipboard.writeText(texto).then(() => {
    btn.textContent = '✓ Copiado!';
    btn.style.background = '#009933';
    btn.style.color = '#fff';
    setTimeout(() => {
      btn.textContent = '📋 Copiar mensagem';
      btn.style.background = '';
      btn.style.color = '';
    }, 2000);
  });
}
['sono','estresse','fadiga','dor'].forEach(c => atualizarSlider(c, 3));
</script>
